---
import Card from '@/components/common/Card.astro';
import { SITE } from '@/utils/constants';

interface Props {
  title: string;
  department: string;
  location: string;
  type: string;
  experience: string;
  slug: string;
}

const { title, department, location, type, experience, slug } = Astro.props;
---

<a href={`${SITE.base}/careers/${slug}`} class="block group">
  <Card class="hover:border-primary-light/50 transition-colors">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary dark:group-hover:text-primary-light transition-colors">
          {title}
        </h3>
        <div class="mt-2 flex flex-wrap gap-2">
          <span class="text-xs px-2 py-0.5 rounded-full bg-primary-light/10 text-primary dark:text-primary-light">
            {department}
          </span>
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
            {location}
          </span>
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
            {type}
          </span>
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
            {experience}
          </span>
        </div>
      </div>
      <span class="text-sm text-primary dark:text-primary-light font-medium shrink-0">
        자세히 보기 →
      </span>
    </div>
  </Card>
</a>
