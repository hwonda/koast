---
import { TIMELINE } from '@/data/company';
---

<section class="bg-gray-50 dark:bg-gray-800/50">
  <div class="max-w-4xl mx-auto px-6 py-20">
    <h2 class="text-3xl font-bold text-center text-gray-900 dark:text-white mb-12">연혁</h2>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-[7px] md:left-1/2 md:-translate-x-px top-0 bottom-0 w-px bg-gray-300 dark:bg-gray-600"></div>

      <div class="space-y-6">
        {TIMELINE.map((item, i) => (
          <div class="relative flex gap-6 md:gap-0">
            {/* Dot */}
            <div class="absolute left-0 md:left-1/2 md:-translate-x-1/2 w-4 h-4 rounded-full bg-primary dark:bg-primary-light border-4 border-gray-50 dark:border-gray-800 mt-0.5"></div>

            {/* Year - always on left for mobile, alternating for desktop */}
            <div class={`hidden md:block md:w-1/2 ${i % 2 === 0 ? 'md:text-right md:pr-8' : 'md:text-left md:pl-8 md:order-2'}`}>
              <span class="text-lg font-bold text-primary dark:text-primary-light">{item.year}</span>
            </div>

            {/* Content */}
            <div class={`ml-8 md:ml-0 md:w-1/2 ${i % 2 === 0 ? 'md:pl-8' : 'md:pr-8 md:text-right md:order-1'}`}>
              <span class="md:hidden text-sm font-bold text-primary dark:text-primary-light">{item.year}</span>
              <ul class="space-y-1 mt-1 md:mt-0">
                {item.events.map((event) => (
                  <li class="text-sm text-gray-600 dark:text-gray-400">{event}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
