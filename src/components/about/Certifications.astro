---
import SectionHeading from '@/components/common/SectionHeading.astro';
import { CERTIFICATIONS, CAPABILITIES } from '@/data/company';
---

<section class="max-w-6xl mx-auto px-6 py-20">
  <div class="grid md:grid-cols-2 gap-12">
    <!-- Certifications -->
    <div>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">인증·등록</h3>
      <div class="flex flex-wrap gap-2">
        {CERTIFICATIONS.map((cert) => (
          <span class="text-sm px-3 py-1.5 rounded-full bg-primary-light/10 text-primary dark:text-primary-light border border-primary-light/20">
            {cert}
          </span>
        ))}
      </div>
    </div>

    <!-- Capabilities -->
    <div>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">조직·역량</h3>
      <div class="space-y-3">
        {CAPABILITIES.map((cap) => (
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-primary-medium dark:bg-primary-light shrink-0"></div>
            <span class="text-gray-700 dark:text-gray-300">{cap}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
