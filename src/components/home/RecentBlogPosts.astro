---
import SectionHeading from '@/components/common/SectionHeading.astro';
import Button from '@/components/common/Button.astro';
import { SITE } from '@/utils/constants';

// Phase 4에서 Content Collections 연결 예정
// 지금은 placeholder
---

<section class="bg-gray-50 dark:bg-gray-800/50">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <SectionHeading
      title="블로그"
      subtitle="기술 인사이트와 회사 소식을 공유합니다."
    />

    <div class="text-center text-gray-400 dark:text-gray-500 py-12">
      <p>블로그 포스트 준비 중입니다.</p>
    </div>

    <div class="text-center">
      <Button href={`${SITE.base}/blog`} variant="secondary">
        블로그 보기
      </Button>
    </div>
  </div>
</section>
