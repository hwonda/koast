---
import Button from '@/components/common/Button.astro';
import { SITE } from '@/utils/constants';
---

<section class="bg-primary dark:bg-primary/90">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- 채용 유도 -->
      <div>
        <h3 class="text-2xl font-bold text-white">함께 만들어갈 인재를 찾습니다</h3>
        <p class="mt-3 text-primary-light/80 leading-relaxed">
          해양·기상 데이터 기술의 미래를 함께 만들 인재를 찾습니다.
        </p>
        <div class="mt-6">
          <Button href={`${SITE.base}/careers`} variant="outline" class="!border-white !text-white hover:!bg-white/10">
            채용 바로가기
          </Button>
        </div>
      </div>

      <!-- 문의 유도 -->
      <div>
        <h3 class="text-2xl font-bold text-white">프로젝트를 상담하세요</h3>
        <p class="mt-3 text-primary-light/80 leading-relaxed">
          프로젝트 상담, 솔루션 도입, 기술 협력 문의를 환영합니다.
        </p>
        <div class="mt-6">
          <Button href={`${SITE.base}/contact`} variant="outline" class="!border-white !text-white hover:!bg-white/10">
            문의하기
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
