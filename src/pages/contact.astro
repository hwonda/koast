---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/contact/ContactForm.tsx';
import CompanyInfo from '@/components/contact/CompanyInfo.astro';
---

<PageLayout title="문의" description="프로젝트 상담, 솔루션 도입, 기술 협력 문의를 환영합니다.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="max-w-3xl mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">문의하기</h1>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
        해양·기상 데이터 시스템 구축이 필요하신가요?<br />
        관측, 예측, 시각화, 시스템 통합까지 목적에 맞는 솔루션을 제안드립니다.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-10">
      <div class="lg:col-span-2">
        <ContactForm client:visible />
      </div>
      <div>
        <CompanyInfo />
      </div>
    </div>
  </section>
</PageLayout>
