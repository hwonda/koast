---
import PageLayout from '@/layouts/PageLayout.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categories = [...new Set(posts.map((p) => p.data.category))];
---

<PageLayout title="블로그" description="해양·기상 데이터 기술에 관한 인사이트와 소식을 공유합니다.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <SectionHeading
      title="블로그"
      subtitle="해양·기상 데이터 기술에 관한 인사이트와 소식을 공유합니다."
    />

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-10 justify-center">
      {categories.map((cat) => (
        <span class="text-sm px-3 py-1 rounded-full bg-primary-light/10 text-primary dark:text-primary-light">
          {cat}
        </span>
      ))}
    </div>

    <!-- Posts grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          publishedAt={post.data.publishedAt}
          category={post.data.category}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center text-gray-400 dark:text-gray-500 py-12">
        <p>아직 작성된 블로그 포스트가 없습니다.</p>
      </div>
    )}
  </section>
</PageLayout>
