---
import PageLayout from '@/layouts/PageLayout.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';
import ServiceCard from '@/components/services/ServiceCard.astro';
import Button from '@/components/common/Button.astro';
import { SERVICES, SOLUTIONS } from '@/data/services';
import { SITE } from '@/utils/constants';
---

<PageLayout title="서비스" description="한국해양기상기술이 제공하는 해양·기상 데이터 통합 솔루션을 소개합니다.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <SectionHeading
      title="서비스"
      subtitle="관측부터 시각화까지, 고객의 목적에 맞는 최적의 솔루션을 제공합니다."
    />

    <div class="space-y-6">
      {SERVICES.map((service) => (
        <ServiceCard service={service} />
      ))}
    </div>
  </section>

  <!-- Solutions -->
  <section class="bg-gray-50 dark:bg-gray-800/50">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <SectionHeading
        title="대표 솔루션"
        subtitle="자체 개발한 소프트웨어와 하드웨어로 현장의 문제를 해결합니다."
      />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {SOLUTIONS.map((solution) => (
          <div class="flex items-center gap-3 p-4 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
            <div class="w-2 h-2 rounded-full bg-primary-medium dark:bg-primary-light shrink-0"></div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">{solution}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">프로젝트를 상담하세요</h2>
    <p class="mt-3 text-gray-500 dark:text-gray-400">
      관측, 예측, 시각화, 시스템 통합까지 목적에 맞는 솔루션을 제안드립니다.
    </p>
    <div class="mt-6">
      <Button href={`${SITE.base}/contact`} size="lg">문의하기</Button>
    </div>
  </section>
</PageLayout>
